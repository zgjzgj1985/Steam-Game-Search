# =============================================
# Steam Game Search - 部署环境变量配置
# =============================================
# 复制此文件为 .env.local 或在 Zeabur 控制台中配置
# =============================================

# =============================================
# 基础配置
# =============================================

# Node 环境（生产环境必须为 production）
NODE_ENV=production

# 数据库（SQLite，生产环境使用 ./dev.db）
DATABASE_URL=file:./dev.db

# 站点基础 URL（分析页面内部 fetch 回调用）
# 替换为你的实际域名，例如：https://steam-game-search.zeabur.app
NEXT_PUBLIC_BASE_URL=https://your-app.zeabur.app

# =============================================
# LLM API 配置
# =============================================
# 支持的提供商: openai | ollama | openrouter | novai | qianwen
LLM_PROVIDER=openrouter

# OpenRouter API（推荐，支持多种模型）
# 获取地址: https://openrouter.ai/keys
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://us.novaiapi.com/v1
LLM_MODEL=your-model-here

# 最大输出 tokens 数（根据模型限制调整）
LLM_MAX_TOKENS=32768

# =============================================
# 其他 LLM 提供商（按需配置）
# =============================================

# 通义千问配置
# LLM_PROVIDER=qianwen
# DASHSCOPE_API_KEY=your_api_key_here
# LLM_MODEL_QIANWEN=qwen3.6-plus
# LLM_BASE_URL_QIANWEN=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI 配置
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# =============================================
# 本地开发配置（仅本地开发时使用）
# =============================================
# 开发环境将 NODE_ENV=development
# 将 NEXT_PUBLIC_BASE_URL=http://localhost:3000
