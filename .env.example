DATABASE_URL="file:./dev.db"

# 站点基础 URL（分析页面内部 fetch 回调用）
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# LLM API 配置
# 提供商: qianwen | openai | ollama
LLM_PROVIDER="qianwen"

# 通义千问（qianwen）
DASHSCOPE_API_KEY="your-api-key-here"
LLM_BASE_URL_QIANWEN="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_MODEL_QIANWEN="qwen3.6-plus"

# OpenAI（openai）
LLM_API_KEY=""
LLM_BASE_URL_OPENAI="https://api.openai.com/v1"
LLM_MODEL_OPENAI="gpt-4o-mini"

# Ollama（ollama）
LLM_BASE_URL_OLLAMA="http://localhost:11434/v1"
LLM_MODEL_OLLAMA="llama3"

# 当前生效（由 LLM_PROVIDER 决定）
LLM_MODEL="qwen3.6-plus"
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_MAX_TOKENS=8192
