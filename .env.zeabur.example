# ===============================================
# Zeabur 部署环境变量配置
# ===============================================
# 在 Zeabur 控制台中添加以下环境变量
# 详细说明请参考 .env.deploy.example
# ===============================================

# Node 环境（生产环境必须为 production）
NODE_ENV=production

# 数据库（SQLite）
DATABASE_URL=file:./dev.db

# 站点基础 URL（替换为你的 Zeabur 应用地址）
NEXT_PUBLIC_BASE_URL=https://steam-game-search.zeabur.app

# LLM API 配置
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-oyeifuXY5k31R5R1SqyPOnZoX01o1bwoF6Reqs4JmumB0jae
LLM_BASE_URL=https://us.novaiapi.com/v1
LLM_MODEL=[次]gemini-3.1-pro-preview-thinking
LLM_MAX_TOKENS=32768
