{
  "name": "turn-based-analyzer",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "stop:dev": "powershell -Command \"Get-NetTCPConnection -LocalPort 3000,3001,3002 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess | ForEach-Object { Stop-Process -Id $_ -Force }\"",
    "dev": "next dev",
    "dev:clean": "node scripts/clean-next.js && next dev",
    "dev:fresh": "npm run stop:dev && npm run dev:clean",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "db:build": "tsx scripts/build-steam-db.ts",
    "build:meta": "python scripts/build-games-meta.py",
    "precompute": "ts-node --esm scripts/precompute.ts",
    "update-data": "ts-node --esm scripts/update-data.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tabs": "^1.0.4",
    "autoprefixer": "^10.4.19",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.378.0",
    "mermaid": "^10.9.0",
    "next": "14.2.35",
    "postcss": "^8.4.38",
    "react": "18.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "18.2.0",
    "recharts": "^2.12.7",
    "swr": "^2.2.5",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^3.4.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.12.12",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "autoprefixer": "^10.4.19",
    "case-sensitive-paths-webpack-plugin": "^2.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "kaggle": "^0.0.1",
    "playwright": "^1.59.1",
    "postcss": "^8.4.38",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
